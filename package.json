{
  "name": "fastmessage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted, end-to-end-encrypted messenger that runs on a Raspberry Pi behind a Cloudflare Tunnel.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:server": "pnpm --filter @fastmessage/server dev",
    "dev:web": "pnpm --filter @fastmessage/web dev",
    "build:web": "pnpm --filter @fastmessage/web build",
    "start": "pnpm --filter @fastmessage/server start",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
