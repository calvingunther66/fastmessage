# ---------------------------------------------------------------------------
# FastMessage configuration. Copy to `.env` and fill in. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- Server ---------------------------------------------------------------
# Port the Node server listens on inside the container.
PORT=8080
# Bind address. 0.0.0.0 so the Docker network / cloudflared can reach it.
HOST=0.0.0.0
# Public origin clients use. Used for Web Push, CORS and link generation.
PUBLIC_ORIGIN=https://message.calvingunther.com
# Comma-separated list of allowed CORS origins (the web app origin).
CORS_ORIGINS=https://message.calvingunther.com
# Secret used to sign/verify opaque session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=change-me-to-a-long-random-string
# Where SQLite + encrypted blobs live (mounted as a Docker volume).
DATA_DIR=/data

# Admin half of the dual-key lockdown unlock. Keep this secret to yourself (the
# admin). A hard-locked account needs BOTH the user's recovery key and an admin
# token derived from this secret. Generate the per-user token with:
#   ADMIN_UNLOCK_SECRET=... node server/scripts/admin-unlock-token.mjs <userId>
ADMIN_UNLOCK_SECRET=change-me-admin-unlock-secret
# Max attachment ciphertext size in bytes (default 50 MiB).
MAX_BLOB_BYTES=52428800

# --- Web Push (VAPID) -----------------------------------------------------
# Generate a keypair with: pnpm --filter @fastmessage/server exec node scripts/gen-vapid.mjs
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:calvin@calvingunther.com

# --- Cloudflare Tunnel ----------------------------------------------------
# Token from `cloudflared tunnel create` / the Zero Trust dashboard.
# Used by the cloudflared container in docker-compose.
TUNNEL_TOKEN=

# --- TURN / coturn (voice & video, Phase 7) -------------------------------
# A long random shared secret for time-limited TURN credentials.
TURN_SECRET=change-me-too
# Public hostname/IP where coturn is reachable (see README caveat about UDP).
TURN_PUBLIC_HOST=turn.calvingunther.com
TURN_REALM=calvingunther.com
